{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Geno",
  "scopeName": "source.geno",
  "patterns": [
    { "include": "#comments" },
    { "include": "#fstrings" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#block-endings" },
    { "include": "#function-definition" },
    { "include": "#type-definition" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#builtin-types" },
    { "include": "#types" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.geno",
          "match": "//.*$"
        },
        {
          "name": "comment.block.geno",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "include": "#comments" }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.geno",
          "begin": "(?<!f)\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.geno",
              "match": "\\\\[nrt\\\\\"'0]"
            }
          ]
        }
      ]
    },
    "fstrings": {
      "patterns": [
        {
          "name": "string.interpolated.geno",
          "begin": "f\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.geno",
              "match": "\\\\[nrt\\\\\"'0]"
            },
            {
              "name": "meta.interpolation.geno",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.geno" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.geno" }
              },
              "patterns": [
                { "include": "source.geno" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.geno",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.hex.geno",
          "match": "\\b0[xX][0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.integer.binary.geno",
          "match": "\\b0[bB][01_]+\\b"
        },
        {
          "name": "constant.numeric.integer.geno",
          "match": "\\b\\d[\\d_]*\\b"
        }
      ]
    },
    "block-endings": {
      "patterns": [
        {
          "match": "\\b(end)\\s+(func)\\s+([a-z_][a-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.control.end.geno" },
            "2": { "name": "storage.type.function.geno" },
            "3": { "name": "entity.name.function.geno" }
          }
        },
        {
          "match": "\\b(end)\\s+(func|fn|if|while|for|match|try|trait|impl|test)\\b",
          "captures": {
            "1": { "name": "keyword.control.end.geno" },
            "2": { "name": "keyword.control.geno" }
          }
        },
        {
          "name": "keyword.control.end.geno",
          "match": "\\bend\\b"
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "match": "\\b(func)\\s+([a-z_][a-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.function.geno" },
            "2": { "name": "entity.name.function.geno" }
          }
        }
      ]
    },
    "type-definition": {
      "patterns": [
        {
          "match": "\\b(type)\\s+([A-Z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.geno" },
            "2": { "name": "entity.name.type.definition.geno" }
          }
        },
        {
          "match": "\\b(trait)\\s+([A-Z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.trait.geno" },
            "2": { "name": "entity.name.type.trait.geno" }
          }
        },
        {
          "match": "\\b(impl)\\s+([A-Z][A-Za-z0-9_]*)\\s+(for)\\s+([A-Z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.impl.geno" },
            "2": { "name": "entity.name.type.trait.geno" },
            "3": { "name": "keyword.control.geno" },
            "4": { "name": "entity.name.type.geno" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow.geno",
          "match": "\\b(if|else|while|for|in|match|with|return|break|continue)\\b"
        },
        {
          "name": "keyword.control.trycatch.geno",
          "match": "\\b(try|catch|throw)\\b"
        },
        {
          "name": "keyword.control.async.geno",
          "match": "\\b(async|await)\\b"
        },
        {
          "name": "keyword.control.do.geno",
          "match": "\\bdo\\b"
        },
        {
          "name": "keyword.control.then.geno",
          "match": "\\bthen\\b"
        },
        {
          "name": "storage.type.geno",
          "match": "\\b(func|let|var|type|trait|impl|import|test)\\b"
        },
        {
          "name": "keyword.operator.logical.geno",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "constant.language.boolean.geno",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "keyword.other.spec.geno",
          "match": "\\b(requires|ensures|example|assert)\\b"
        },
        {
          "name": "keyword.other.geno",
          "match": "\\b(ref|fn|where)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipeline.geno",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.fat-arrow.geno",
          "match": "=>"
        },
        {
          "name": "keyword.operator.arrow.geno",
          "match": "->"
        },
        {
          "name": "keyword.operator.comparison.geno",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.power.geno",
          "match": "\\*\\*"
        },
        {
          "name": "keyword.operator.arithmetic.geno",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.assignment.geno",
          "match": "(?<!=|!)=(?!=|>)"
        },
        {
          "name": "keyword.operator.bitwise.geno",
          "match": "<<|>>|&|\\^|~"
        },
        {
          "name": "keyword.operator.question.geno",
          "match": "\\?"
        },
        {
          "name": "punctuation.separator.pipe.geno",
          "match": "(?<!\\|)\\|(?!>|\\|)"
        }
      ]
    },
    "builtin-types": {
      "patterns": [
        {
          "name": "support.type.builtin.geno",
          "match": "\\b(Int|String|Bool|Float|Unit|List|Map|Set|Option|Result|Array|Vec|MutableMap|Async)\\b"
        },
        {
          "name": "support.type.self.geno",
          "match": "\\bSelf\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.geno",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "\\b([a-z_][a-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.geno" }
          }
        },
        {
          "name": "variable.other.geno",
          "match": "\\b[a-z_][a-z0-9_]*\\b"
        }
      ]
    }
  }
}
