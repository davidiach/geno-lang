# EXPECT: E503
# Pipeline operator abuse to smuggle computation through function
# composition chains: build long pipelines of identity-like
# functions where each stage captures a closure variable and
# passes it down.  The pipeline creates O(n * stages) hidden
# function calls per iteration.  Tests that pipeline-composed
# function calls are step-counted even when the pipeline operator
# syntax obscures the call depth.
func add_offset(offset: Int, x: Int) -> Int
    example 0, 5 -> 5
    return x + offset
end func

func mul_factor(factor: Int, x: Int) -> Int
    example 2, 3 -> 6
    return x * factor
end func

func negate(x: Int) -> Int
    example 5 -> -5
    return 0 - x
end func

func abs_val(x: Int) -> Int
    example -5 -> 5
    if x < 0 then
        return 0 - x
    end if
    return x
end func

func main() -> Int
    var total: Int = 0
    var i: Int = 0
    while i < 500000 do
        let result: Int = i
            |> fn(x: Int) -> add_offset(offset: 1, x: x)
            |> fn(x: Int) -> mul_factor(factor: 2, x: x)
            |> negate
            |> abs_val
            |> fn(x: Int) -> add_offset(offset: i, x: x)
            |> fn(x: Int) -> mul_factor(factor: 3, x: x)
            |> abs_val
        total = total + result
        i = i + 1
    end while
    return total
end func
