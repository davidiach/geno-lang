# EXPECT: E503
# Grow a list of pairs in a tight loop, testing step
# counting with repeated append operations.
func main() -> Int
    var lst: List[Int] = []
    var i: Int = 0
    while i < 1000000 do
        lst = append(lst, i * i)
        i = i + 1
    end while
    return length(lst)
end func
