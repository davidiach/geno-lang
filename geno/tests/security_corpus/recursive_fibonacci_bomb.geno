# EXPECT: E503
# Naive recursive Fibonacci with huge input.
# Exponential call tree should hit step limit quickly.
func fib(n: Int) -> Int
    example 0 -> 0
    example 1 -> 1
    if n <= 1 then
        return n
    end if
    return fib(n - 1) + fib(n - 2)
end func

func main() -> Int
    return fib(100)
end func
