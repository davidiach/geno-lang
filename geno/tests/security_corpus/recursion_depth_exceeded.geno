# EXPECT: E502
# Mutual recursion should be caught by the call-depth limit.
# Verifies that mutually recursive functions do not evade
# the single-function recursion depth tracker.
func ping(n: Int) -> Int
    example 0 -> 0
    if n <= 0 then
        return 0
    end if
    return pong(n - 1)
end func

func pong(n: Int) -> Int
    example 0 -> 0
    if n <= 0 then
        return 0
    end if
    return ping(n - 1)
end func

func main() -> Int
    return ping(100000)
end func
